# 3d Lennard-Jones melt to vapor-liquid mixture GEMC
# mpirun -np 5 ./lmp -in in.gemc.lj -p 1 4

variable        temp index 1.0 
variable        ntranslate index 10
variable        nexchange index 10 
variable        nvolume index 10
variable        displace index 0.5
variable        max_dlogvolratio index 0.5
variable        nsteps index 10000

units           lj
atom_style      atomic

# initialize gas state in partition 1

partition       yes 1 lattice fcc 0.05
partition       yes 1 region box block 0 1 0 1 0 1

# initialize liquid state in partition 2

partition       yes 2 lattice fcc 0.6
partition       yes 2 region box block 0 3 0 3 0 3

create_box      1 box
create_atoms    1 box
mass            1 1.0

velocity        all create 3.0 87287 loop geom 

pair_style      lj/cut 2.5
pair_coeff      1 1 1.0 1.0 2.5

neighbor        0.3 bin
neigh_modify    every 1 delay 5 check yes

fix             1 all nve

thermo          50
thermo_style    custom step temp pe etotal press vol atoms density
run             250
unfix           1

velocity        all create 0.0 87287 loop geom

#   args: nevery ntranslate nexchange nvolume box_temp displace max_dlogvolratio seed 
fix              2 all gemc 1 ${ntranslate} ${nexchange} ${nvolume} ${temp} ${displace} ${max_dlogvolratio} 29494

variable        mydensity equal density
fix             3 all ave/time 1 50 50 v_mydensity ave window 20
thermo_style    custom step temp pe etotal press vol atoms density f_3

run             ${nsteps}
